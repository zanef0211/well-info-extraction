# ========== 应用配置 ==========
APP_NAME=WellInfo Extractor
APP_VERSION=v1.0.0
DEBUG=false

# ========== LLM 配置 ==========
# 通义千问 API Key: https://dashscope.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_CLASSIFY=qwen2.5-14b-instruct
LLM_MODEL_EXTRACT=qwen2.5-72b-instruct
LLM_MODEL_WELLNO=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.05
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# ========== OCR 配置 ==========
OCR_USE_GPU=false
OCR_LANG=ch
OCR_DROP_SCORE=0.5

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://wellinfo:wellinfo123@localhost:5432/wellinfo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
REDIS_MAX_CONNECTIONS=10

# ========== 存储配置 ==========
STORAGE_PATH=./storage
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed
CACHE_DIR=./storage/cache

# ========== API 配置 ==========
API_PREFIX=/api/v1
MAX_FILE_SIZE=52428800
BATCH_MAX_FILES=100

# ========== JWT 配置 ==========
# 请使用随机生成的密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 限流配置 ==========
RATE_LIMIT_PER_USER=10

# ========== 批量处理配置 ==========
BATCH_MAX_WORKERS=4
BATCH_TIMEOUT_SECONDS=120

# ========== 校验配置 ==========
CONFIDENCE_THRESHOLD=0.70
